{
  "name": "godot-forge-mcp",
  "version": "0.1.0",
  "description": "Intelligent MCP server for Godot 4.3+ game development",
  "type": "module",
  "bin": {
    "godot-forge-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "godot-plugin"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "godot",
    "game-development",
    "model-context-protocol",
    "ai",
    "gdscript",
    "game-engine"
  ],
  "author": "Zane Hill <zanehill01@github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zanehill01/godot-forge-mcp.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
